# MicroGRID native app — environment variables
# Copy to .env (gitignored) for local dev.

# Supabase — required (same project as CRM)
EXPO_PUBLIC_SUPABASE_URL=https://hzymsezqfxzpbcqryeim.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon/publishable key>

# Sentry — Phase 2 (separate project from CRM: 'microgrid-mobile' on
# microgrid-energy.sentry.io). DSN-gated: when unset, Sentry init is a no-op.
# Greg action #489 covers project creation.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development

# PostHog — Phase 5+ instrumentation (optional; not currently wired)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# API base — defaults to production CRM at app.gomicrogridenergy.com
# Override only for local dev against a Vercel preview URL.
EXPO_PUBLIC_API_BASE_URL=https://app.gomicrogridenergy.com
